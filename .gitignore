# Co-Ownership Vehicle System - Git Ignore Configuration

# =============================================================================
# EXCLUDE DOCUMENTATION AND SCRIPTS (as requested)
# =============================================================================

# PowerShell scripts
*.ps1

# Batch files
*.bat

# Markdown documentation files
*.md

# Claude Code configuration
.claude/

# BUT ALLOW ESSENTIAL SETUP FILES
!.env.template
!.gitignore

# =============================================================================
# CREDENTIALS AND SENSITIVE DATA
# =============================================================================

# Local credential files (DO NOT COMMIT)
credentials.json
secrets.json
local-config.json
.env
.env.local
.env.development
.env.production

# BUT ALLOW .env.template
!.env.template

# BUT ALLOW TEMPLATE FILES
!.env.template

# Connection strings backup
*connection-strings*
*credentials*
*secrets*

# Environment variable files (contain sensitive data)
environment-variables.txt
setup-environment.ps1

# EXCEPT template files
!*template*

# Postman environment files (may contain secrets)
*_Environment.json
*environment*.json

# BUT ALLOW example/template files
!*example*.json
!*template*.json

# =============================================================================
# .NET AND VISUAL STUDIO
# =============================================================================


{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },
  "MqttSettings": {
    "Host": "broker.hivemq.com",
    "Port": 1883,
    "Username": "",
    "Password": ""
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "AiDiagnosis": {
    "Provider": "",
    "Model": "gpt-4o",
    "MaxTokens": 1024,
    "GeminiModel": "",
    "GeminiBaseUrl": ""
  },
  "AiLive": {
    "Enabled": true,
    "LiveModel": "gemini-live-2.5-flash-preview",
    "VoiceName": null,
    "AuthTokensApiVersion": "v1alpha"
  },
  "Ollama": {
    "BaseUrl": "",
    "Model": "",
    "TimeoutSeconds": 60,
    "IntentClassificationModel": "",
    "IntentClassificationTimeoutSeconds": 12
  },
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "",
    "Audience": "",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "UseSsl": true,
    "SmtpUser": "",
    "SmtpPassword": "",
    "FromAddress": "noreply@example.com",
    "FromName": "Decorative Plant",
    "DisableSending": true,
    "TemplateBasePath": "EmailTemplates"
  },
  "OtpSettings": {
    "Secret": "",
    "RegistrationExpiresMinutes": 10,
    "PasswordResetExpiresMinutes": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "GhnSettings": {
    "BaseUrl": "",
    "Token": "",
    "ShopId": 0
  }
}

# Database Connection
ConnectionStrings__DefaultConnection=Server=(localdb)\\mssqllocaldb;Database=DecorativePlantDB;Trusted_Connection=true;MultipleActiveResultSets=true;TrustServerCertificate=true

# Redis Connection (for refresh token storage)
# For local development, you can use: localhost:6379
# For Docker: redis:6379
# For cloud Redis services, use the provided connection string
ConnectionStrings__Redis=localhost:6379

# JWT Settings
JwtSettings__SecretKey=YourSuperSecretKeyThatShouldBeAtLeast32CharactersLongForHS256Algorithm!
JwtSettings__Issuer=DecorativePlantAPI
JwtSettings__Audience=DecorativePlantClient
JwtSettings__AccessTokenExpirationMinutes=30
JwtSettings__RefreshTokenExpirationDays=7

# Environment
ASPNETCORE_ENVIRONMENT=Development

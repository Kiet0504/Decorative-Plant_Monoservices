# PostgreSQL Database Configuration (used by docker compose services)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=DecorativePlantDB

# pgAdmin Configuration (used by docker compose service)
# Use a long random password in production. Do not expose PGADMIN_PORT publicly;
# prefer SSH tunnel, VPN, or firewall allowlist (docker-compose enables server mode + master password).
PGADMIN_DEFAULT_EMAIL=admin@decorativeplant.com
PGADMIN_DEFAULT_PASSWORD=change-me-strong-password
PGADMIN_PORT=5050

# Database Connection (used by the API app)
# If API runs in Docker compose, use Host=postgres (service name).
# If API runs on host machine (dotnet run), use Host=localhost.
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=DecorativePlantDB;Username=postgres;Password=change-me-strong-password

# Redis Connection (used by the API app)
# If API runs in Docker compose, use redis:6379.
# If API runs on host machine (dotnet run), use localhost:6379.
ConnectionStrings__Redis=redis:6379

# AI Diagnosis
# Provider: OpenAI (default) or GeminiOllama (Gemini Flash detection + local Ollama reasoning)
AiDiagnosis__Provider=OpenAI
# OpenAI — https://platform.openai.com/api-keys (used when Provider=OpenAI)
AiDiagnosis__ApiKey=
AiDiagnosis__Model=gpt-4o
AiDiagnosis__MaxTokens=1024
# Gemini (Google AI Studio) — used when Provider=GeminiOllama for image detection
# AiDiagnosis__GeminiApiKey=
# AiDiagnosis__GeminiModel=gemini-2.5-flash
# AiDiagnosis__GeminiBaseUrl=https://generativelanguage.googleapis.com
# Ollama must be running for reasoning step — see Ollama__* elsewhere / docker-compose
# Set true to route all former-Ollama calls (main chat, JSON intent classifiers, vision JSON, room-scan fallbacks) to Gemini — requires AiDiagnosis__GeminiApiKey. Ollama does not need to be running.
# AiRouting__UseGeminiOnly=false

# Room corner scanner — room photo: Gemini when key is set; optional Ollama vision fallback if Gemini fails or key missing (pull e.g. llava:7b).
# Ranking: Gemini (default) or Ollama (local). Falls back to AiDiagnosis__Gemini* when RoomScan Gemini keys blank.
# Optional: RoomScan__RankProvider=Ollama to rank with local Ollama (see Ollama__*).
# RoomScan__OllamaVisionModel=llava:7b
# Server-wide pipeline: hybrid (Gemini then Ollama fallback) or localOnly (Ollama vision + rank only).
# RoomScan__PipelineMode=hybrid
# RoomScan__GeminiApiKey=
# RoomScan__GeminiModel=
# RoomScan__GeminiBaseUrl=
# RoomScan__RequestTimeoutSeconds=120
# RoomScan__MaxCatalogSnippets=48
# RoomScan__MaxRecommendations=5
# RoomScan__RankProvider=Gemini
# RoomScan__OllamaRankModel=

# Gemini Live (WebSocket) — token minting config
# If your Live session "connects then immediately closes", increase this value.
# AiLive__AuthTokenUses=128

# Ollama (chat + optional small-model intent routing)
# Ollama__BaseUrl=http://localhost:11434
# Ollama__Model=llama3.1:8b
# Ollama__TimeoutSeconds=60
# JSON intent classifiers (image caption, room-scan chat refresh, /ai/chat profile-shop). With AiRouting__UseGeminiOnly=true, an Ollama-style name here is ignored — AiDiagnosis__GeminiModel is used unless you set this to a Gemini id (e.g. gemini-2.0-flash):
# Ollama__IntentClassificationModel=
# Ollama__IntentClassificationTimeoutSeconds=12

# Block obvious harmful user text before LLM calls (chat, diagnosis, garden AI). Set false only for local debugging.
# ContentSafety__Enabled=true

# Restrict /ai/chat to plant-care, shop, garden, and diagnosis topics (keyword gate + stronger system prompt).
# PlantAssistantScope__Enabled=true

# JWT Settings
JwtSettings__SecretKey=YourSuperSecretKeyThatShouldBeAtLeast32CharactersLongForHS256Algorithm!
JwtSettings__Issuer=DecorativePlantAPI
JwtSettings__Audience=DecorativePlantClient
JwtSettings__AccessTokenExpirationMinutes=30
JwtSettings__RefreshTokenExpirationDays=7

# Email (SMTP) – used for OTP, password reset, and future transactional email
# Set DisableSending=true in Development to avoid sending real email
EmailSettings__SmtpHost=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__UseSsl=true
EmailSettings__SmtpUser=your-email@gmail.com
EmailSettings__SmtpPassword=your-app-password
EmailSettings__FromAddress=noreply@yourdomain.com
EmailSettings__FromName=Decorative Plant
EmailSettings__DisableSending=true

# OTP (registration & password reset). Leave empty to use JwtSettings__SecretKey.
# Or set a long random string (e.g. 32+ chars) if you want a separate secret for OTP hashing.
OtpSettings__Secret=
OtpSettings__RegistrationExpiresMinutes=10
OtpSettings__PasswordResetExpiresMinutes=15

# Database — set true on VPS/Production so EF migrations run at API startup (Development always migrates)
Database__ApplyMigrationsOnStartup=false

# Environment
ASPNETCORE_ENVIRONMENT=Development

# Swagger (API docs). Set to true to enable Swagger in Production/Staging.
# In Development, Swagger is always enabled.
SWAGGER_ENABLED=false

# PayOS Payment Gateway
PayOS__ClientId=your-payos-client-id
PayOS__ApiKey=your-payos-api-key
PayOS__ChecksumKey=your-payos-checksum-key

# GHN (Giao Hang Nhanh) Shipping
# Staging: https://5sao.ghn.dev — Production: https://khachhang.ghn.vn
GhnSettings__BaseUrl=https://dev-online-gateway.ghn.vn
GhnSettings__Token=your-ghn-token
GhnSettings__ClientId=your-ghn-client-id
GhnSettings__ShopId=0

# Docker API service (optional – defaults in docker-compose.yml)
# APP_UID=1654
# APP_GID=1654

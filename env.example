# Database Connection
# 
# Option 1: Local PostgreSQL with Supabase extensions (Docker)
# Uses supabase/postgres image which includes extensions and RLS support
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=DecorativePlantDB;Username=postgres;Password=postgres
#
# Option 2: Supabase PostgreSQL (Cloud)
# Get your connection string from Supabase Dashboard > Settings > Database
# Format: Host=your-project-ref.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=your-password
# Example: ConnectionStrings__DefaultConnection=Host=abcdefghijklmnop.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=your-supabase-password
#
# Connection string format: Host=hostname;Port=5432;Database=database_name;Username=username;Password=password
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=DecorativePlantDB;Username=postgres;Password=postgres

# Redis Connection (for refresh token storage)
# Format: redis://username:password@host:port
# For local development: localhost:6379
# For Docker: redis:6379
# For Redis Labs (cloud): redis://username:password@host:port
# 
# Example for Redis Labs (replace YourPassword with your actual password):
# ConnectionStrings__Redis=redis://default:YourPassword@redis-15270.crce264.ap-east-1-1.ec2.cloud.redislabs.com:15270
ConnectionStrings__Redis=redis://default:YourPassword@redis-15270.crce264.ap-east-1-1.ec2.cloud.redislabs.com:15270

# JWT Settings
JwtSettings__SecretKey=YourSuperSecretKeyThatShouldBeAtLeast32CharactersLongForHS256Algorithm!
JwtSettings__Issuer=DecorativePlantAPI
JwtSettings__Audience=DecorativePlantClient
JwtSettings__AccessTokenExpirationMinutes=30
JwtSettings__RefreshTokenExpirationDays=7

# Environment
ASPNETCORE_ENVIRONMENT=Development
